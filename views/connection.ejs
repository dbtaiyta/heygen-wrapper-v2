<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Connection - HeyGen Wrapper v2</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body class="bg-gray-50 dark:bg-gray-900">
  <div class="flex min-h-screen">
    <aside class="w-64 bg-white dark:bg-gray-800 border-r border-gray-200 dark:border-gray-700">
      <div class="p-6">
        <h1 class="text-xl font-bold text-gray-900 dark:text-white">HeyGen Wrapper</h1>
        <p class="text-sm text-gray-500 dark:text-gray-400 mt-1">v2.0</p>
      </div>
      <nav class="px-4 space-y-1">
        <a href="/" class="flex items-center px-4 py-2 text-sm font-medium rounded-lg text-gray-700 hover:bg-gray-50 dark:text-gray-300 dark:hover:bg-gray-700">
          <svg class="w-5 h-5 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"></path></svg>
          Dashboard
        </a>
        <a href="/api-keys" class="flex items-center px-4 py-2 text-sm font-medium rounded-lg text-gray-700 hover:bg-gray-50 dark:text-gray-300 dark:hover:bg-gray-700">
          <svg class="w-5 h-5 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H4a1 1 0 01-1-1v-2.586a1 1 0 01.293-.707l5.964-5.964A6 6 0 1121 9z"></path></svg>
          API Keys
        </a>
        <a href="/settings/connection" class="flex items-center px-4 py-2 text-sm font-medium rounded-lg bg-blue-50 text-blue-700 dark:bg-blue-900/20 dark:text-blue-400">
          <svg class="w-5 h-5 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"></path></svg>
          Connection
        </a>
        <a href="/settings/proxy" class="flex items-center px-4 py-2 text-sm font-medium rounded-lg text-gray-700 hover:bg-gray-50 dark:text-gray-300 dark:hover:bg-gray-700">
          <svg class="w-5 h-5 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 12h14M5 12a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v4a2 2 0 01-2 2M5 12a2 2 0 00-2 2v4a2 2 0 002 2h14a2 2 0 002-2v-4a2 2 0 00-2-2m-2-4h.01M17 16h.01"></path></svg>
          Proxy
        </a>
        <a href="/docs" class="flex items-center px-4 py-2 text-sm font-medium rounded-lg text-gray-700 hover:bg-gray-50 dark:text-gray-300 dark:hover:bg-gray-700">
          <svg class="w-5 h-5 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg>
          API Docs
        </a>
      </nav>
    </aside>
    <main class="flex-1 overflow-y-auto">
      <div class="px-8 py-6">
        <div x-data="connection()" x-init="init()">
          <div class="mb-6">
            <h1 class="text-3xl font-bold text-gray-900 dark:text-white">HeyGen Connection</h1>
            <p class="text-gray-500 dark:text-gray-400 mt-1">Manage your HeyGen browser session</p>
          </div>

          <!-- Session Status Card -->
          <div class="bg-white dark:bg-gray-800 rounded-lg shadow p-6 mb-6">
            <div class="flex items-center justify-between mb-4">
              <h2 class="text-lg font-semibold text-gray-900 dark:text-white">Session Status</h2>
              <span class="px-3 py-1 text-sm font-semibold rounded-full" 
                    :class="hasSession ? 'bg-green-100 text-green-800 dark:bg-green-900/20 dark:text-green-400' : 'bg-red-100 text-red-800 dark:bg-red-900/20 dark:text-red-400'"
                    x-text="hasSession ? 'Connected' : 'Disconnected'"></span>
            </div>
            
            <template x-if="hasSession">
              <div class="space-y-2 text-sm text-gray-700 dark:text-gray-300">
                <p>✓ Browser session is active</p>
                <p>✓ Ready to generate videos</p>
              </div>
            </template>
            
            <template x-if="!hasSession">
              <div class="space-y-2 text-sm text-gray-700 dark:text-gray-300">
                <p>✗ No active session</p>
                <p>✗ You need to upload a session file</p>
              </div>
            </template>
          </div>

          <!-- Upload Session Instructions -->
          <div class="bg-blue-50 dark:bg-blue-900/20 border border-blue-200 dark:border-blue-800 rounded-lg p-6 mb-6">
            <h3 class="text-lg font-semibold text-blue-900 dark:text-blue-300 mb-3">🌐 Easy Setup - Login in Browser</h3>
            <p class="text-sm text-blue-800 dark:text-blue-400 mb-4">
              Click the button below to open a browser window where you can login to HeyGen directly!
            </p>
            <button @click="openBrowserViewer" class="px-8 py-3 bg-blue-600 text-white rounded-lg hover:bg-blue-700 font-semibold flex items-center space-x-2">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9"></path></svg>
              <span>Open Browser & Login to HeyGen</span>
            </button>
            <p class="text-xs text-blue-700 dark:text-blue-500 mt-3">
              💡 After logging in, click "Save Session" to complete setup. Session lasts 2-4 weeks!
            </p>
          </div>

          <div class="my-6 flex items-center">
            <div class="flex-1 border-t border-gray-300 dark:border-gray-600"></div>
            <span class="px-4 text-sm text-gray-500 dark:text-gray-400">OR</span>
            <div class="flex-1 border-t border-gray-300 dark:border-gray-600"></div>
          </div>

          <!-- Upload Session (Alternative) -->
          <div class="bg-gray-50 dark:bg-gray-800/50 border border-gray-200 dark:border-gray-700 rounded-lg p-6 mb-6">
            <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-3">📦 Alternative: Upload Session ZIP</h3>
            <p class="text-sm text-gray-600 dark:text-gray-400 mb-4">
              If you prefer, run <code class="bg-gray-200 dark:bg-gray-700 px-2 py-1 rounded text-xs">npm run export-session</code> on your local machine and upload the ZIP file.
            </p>
            
            <form @submit.prevent="uploadSession" class="space-y-4">
              <div>
                <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">
                  Select heygen-session.zip
                </label>
                <input 
                  type="file" 
                  @change="fileSelected" 
                  accept=".zip"
                  class="block w-full text-sm text-gray-900 dark:text-white border border-gray-300 dark:border-gray-600 rounded-lg cursor-pointer bg-gray-50 dark:bg-gray-700 focus:outline-none"
                />
              </div>
              
              <button 
                type="submit" 
                :disabled="!selectedFile || uploading"
                class="px-6 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 disabled:opacity-50 disabled:cursor-not-allowed"
              >
                <span x-show="!uploading">Upload Session</span>
                <span x-show="uploading">Uploading...</span>
              </button>
            </form>
          </div>

          <!-- Actions -->
          <div class="flex space-x-3">
            <template x-if="hasSession">
              <button @click="downloadSession" class="px-6 py-2 border border-blue-600 text-blue-600 dark:text-blue-400 rounded-lg hover:bg-blue-50 dark:hover:bg-blue-900/20">
                Download Backup
              </button>
            </template>
            
            <template x-if="hasSession">
              <button @click="clearSession" class="px-6 py-2 border border-red-600 text-red-600 dark:text-red-400 rounded-lg hover:bg-red-50 dark:hover:bg-red-900/20">
                Clear Session
              </button>
            </template>
          </div>

          <!-- Status Messages -->
          <div x-show="statusMessage" class="mt-6 p-4 rounded-lg" :class="statusType === 'success' ? 'bg-green-50 dark:bg-green-900/20 text-green-800 dark:text-green-400 border border-green-200' : 'bg-red-50 dark:bg-red-900/20 text-red-800 dark:text-red-400 border border-red-200'">
            <p class="text-sm" x-text="statusMessage"></p>
          </div>
        </div>
      </div>
    </main>
  </div>

<script>
function connection() {
  return {
    hasSession: false,
    selectedFile: null,
    uploading: false,
    statusMessage: '',
    statusType: 'success',
    
    init() {
      this.checkSession();
    },
    
    async checkSession() {
      try {
        const res = await fetch('/api/session/status');
        const data = await res.json();
        this.hasSession = data.has_session;
      } catch (error) {
        console.error('Failed to check session:', error);
      }
    },

    async openBrowserViewer() {
      try {
        this.statusMessage = 'Opening browser...';
        this.statusType = 'success';

        const res = await fetch('/admin/browser/start', {
          method: 'POST'
        });

        const data = await res.json();

        if (data.success) {
          // Open browser viewer in new window
          const width = 1320;
          const height = 900;
          const left = (screen.width - width) / 2;
          const top = (screen.height - height) / 2;

          window.open(
            data.viewerUrl,
            'HeyGen Login',
            `width=${width},height=${height},left=${left},top=${top}`
          );

          this.showStatus('Browser opened! Login and click "Save Session" when done.', 'success');
        } else {
          this.showStatus('Failed to open browser', 'error');
        }
      } catch (error) {
        console.error('Failed to open browser:', error);
        this.showStatus('Failed to open browser', 'error');
      }
    },
    
    fileSelected(event) {
      this.selectedFile = event.target.files[0];
    },
    
    async uploadSession() {
      if (!this.selectedFile) return;
      
      this.uploading = true;
      this.statusMessage = '';
      
      try {
        const formData = new FormData();
        formData.append('session', this.selectedFile);
        
        const res = await fetch('/admin/session/upload', {
          method: 'POST',
          body: formData
        });
        
        const data = await res.json();
        
        if (res.ok) {
          this.hasSession = data.sessionValid;
          this.showStatus('Session uploaded successfully! ' + (data.sessionValid ? 'Session is valid.' : 'Please check if session is working.'), 'success');
          this.selectedFile = null;
          // Reset file input
          document.querySelector('input[type="file"]').value = '';
        } else {
          this.showStatus(data.error || 'Failed to upload session', 'error');
        }
      } catch (error) {
        console.error('Failed to upload session:', error);
        this.showStatus('Failed to upload session', 'error');
      } finally {
        this.uploading = false;
      }
    },
    
    async downloadSession() {
      try {
        window.location.href = '/admin/session/download';
        this.showStatus('Session backup downloading...', 'success');
      } catch (error) {
        console.error('Failed to download session:', error);
        this.showStatus('Failed to download session', 'error');
      }
    },
    
    async clearSession() {
      if (!confirm('Are you sure you want to clear the session? You will need to upload a new one.')) return;
      try {
        const res = await fetch('/admin/session/clear', { method: 'POST' });
        if (res.ok) {
          this.hasSession = false;
          this.showStatus('Session cleared', 'success');
        }
      } catch (error) {
        console.error('Failed to clear session:', error);
      }
    },
    
    showStatus(message, type) {
      this.statusMessage = message;
      this.statusType = type;
      setTimeout(() => this.statusMessage = '', 5000);
    }
  }
}
</script>
</body>
</html>
