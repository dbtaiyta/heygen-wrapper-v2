<div x-data="dashboard()" x-init="init()">
  <div class="mb-6">
    <h1 class="text-3xl font-bold text-gray-900 dark:text-white">Dashboard</h1>
    <p class="text-gray-500 dark:text-gray-400 mt-1">Monitor your HeyGen video generation</p>
  </div>

  <!-- Status Cards -->
  <div class="grid grid-cols-1 md:grid-cols-4 gap-6 mb-6">
    <!-- Session Status -->
    <div class="bg-white dark:bg-gray-800 rounded-lg shadow p-6">
      <div class="flex items-center justify-between">
        <div>
          <p class="text-sm font-medium text-gray-600 dark:text-gray-400">Session Status</p>
          <p class="text-2xl font-bold mt-2" :class="sessionStatus === 'connected' ? 'text-green-600' : 'text-red-600'" x-text="sessionStatus === 'connected' ? 'Connected' : 'Disconnected'"></p>
        </div>
        <div class="p-3 rounded-full" :class="sessionStatus === 'connected' ? 'bg-green-100 dark:bg-green-900/20' : 'bg-red-100 dark:bg-red-900/20'">
          <svg class="w-6 h-6" :class="sessionStatus === 'connected' ? 'text-green-600' : 'text-red-600'" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
        </div>
      </div>
    </div>

    <!-- Queue: Waiting -->
    <div class="bg-white dark:bg-gray-800 rounded-lg shadow p-6">
      <div class="flex items-center justify-between">
        <div>
          <p class="text-sm font-medium text-gray-600 dark:text-gray-400">Waiting</p>
          <p class="text-2xl font-bold text-gray-900 dark:text-white mt-2" x-text="queueStats.waiting"></p>
        </div>
        <div class="p-3 bg-yellow-100 dark:bg-yellow-900/20 rounded-full">
          <svg class="w-6 h-6 text-yellow-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
        </div>
      </div>
    </div>

    <!-- Queue: Active -->
    <div class="bg-white dark:bg-gray-800 rounded-lg shadow p-6">
      <div class="flex items-center justify-between">
        <div>
          <p class="text-sm font-medium text-gray-600 dark:text-gray-400">Active</p>
          <p class="text-2xl font-bold text-gray-900 dark:text-white mt-2" x-text="queueStats.active"></p>
        </div>
        <div class="p-3 bg-blue-100 dark:bg-blue-900/20 rounded-full">
          <svg class="w-6 h-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
        </div>
      </div>
    </div>

    <!-- Queue: Completed -->
    <div class="bg-white dark:bg-gray-800 rounded-lg shadow p-6">
      <div class="flex items-center justify-between">
        <div>
          <p class="text-sm font-medium text-gray-600 dark:text-gray-400">Completed</p>
          <p class="text-2xl font-bold text-gray-900 dark:text-white mt-2" x-text="queueStats.completed"></p>
        </div>
        <div class="p-3 bg-green-100 dark:bg-green-900/20 rounded-full">
          <svg class="w-6 h-6 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
        </div>
      </div>
    </div>
  </div>

  <!-- Recent Generations Table -->
  <div class="bg-white dark:bg-gray-800 rounded-lg shadow">
    <div class="px-6 py-4 border-b border-gray-200 dark:border-gray-700">
      <h2 class="text-lg font-semibold text-gray-900 dark:text-white">Recent Generations</h2>
    </div>
    <div class="overflow-x-auto">
      <table class="w-full">
        <thead class="bg-gray-50 dark:bg-gray-700">
          <tr>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">Job ID</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">Avatar</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">Status</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">Progress</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">Timestamp</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">Actions</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-200 dark:divide-gray-700">
          <template x-for="job in jobs" :key="job.job_id">
            <tr class="hover:bg-gray-50 dark:hover:bg-gray-700 cursor-pointer">
              <td class="px-6 py-4 text-sm font-mono text-gray-900 dark:text-white" x-text="job.job_id.substring(0, 8)"></td>
              <td class="px-6 py-4 text-sm text-gray-700 dark:text-gray-300" x-text="job.avatar_name"></td>
              <td class="px-6 py-4">
                <span class="px-2 py-1 text-xs font-semibold rounded-full" 
                      :class="{
                        'bg-green-100 text-green-800 dark:bg-green-900/20 dark:text-green-400': job.status === 'completed',
                        'bg-blue-100 text-blue-800 dark:bg-blue-900/20 dark:text-blue-400': job.status === 'processing',
                        'bg-yellow-100 text-yellow-800 dark:bg-yellow-900/20 dark:text-yellow-400': job.status === 'queued',
                        'bg-red-100 text-red-800 dark:bg-red-900/20 dark:text-red-400': job.status === 'failed'
                      }"
                      x-text="job.status"></span>
              </td>
              <td class="px-6 py-4">
                <div class="flex items-center">
                  <div class="w-32 bg-gray-200 dark:bg-gray-600 rounded-full h-2 mr-2">
                    <div class="bg-blue-600 h-2 rounded-full" :style="`width: ${job.progress}%`"></div>
                  </div>
                  <span class="text-sm text-gray-700 dark:text-gray-300" x-text="`${job.progress}%`"></span>
                </div>
              </td>
              <td class="px-6 py-4 text-sm text-gray-700 dark:text-gray-300" x-text="new Date(job.created_at).toLocaleString()"></td>
              <td class="px-6 py-4 text-sm">
                <button @click="viewJob(job.job_id)" class="text-blue-600 hover:text-blue-800 dark:text-blue-400 dark:hover:text-blue-300">View</button>
              </td>
            </tr>
          </template>
          <template x-if="jobs.length === 0">
            <tr>
              <td colspan="6" class="px-6 py-8 text-center text-gray-500 dark:text-gray-400">No jobs yet. Start generating videos via API.</td>
            </tr>
          </template>
        </tbody>
      </table>
    </div>
  </div>
</div>

<script>
function dashboard() {
  return {
    sessionStatus: 'disconnected',
    queueStats: { waiting: 0, active: 0, completed: 0 },
    jobs: [],
    
    init() {
      this.fetchData();
      setInterval(() => this.fetchData(), 10000); // Auto-refresh every 10s
    },
    
    async fetchData() {
      try {
        // Fetch session status
        const sessionRes = await fetch('/api/session/status');
        const sessionData = await sessionRes.json();
        this.sessionStatus = sessionData.has_session ? 'connected' : 'disconnected';
        
        // Fetch jobs
        const jobsRes = await fetch('/api/jobs');
        const jobsData = await jobsRes.json();
        this.jobs = jobsData.jobs || [];
        
        // Calculate queue stats
        this.queueStats.waiting = this.jobs.filter(j => j.status === 'queued').length;
        this.queueStats.active = this.jobs.filter(j => j.status === 'processing').length;
        this.queueStats.completed = this.jobs.filter(j => j.status === 'completed').length;
      } catch (error) {
        console.error('Failed to fetch data:', error);
      }
    },
    
    viewJob(jobId) {
      window.location.href = `/jobs/${jobId}`;
    }
  }
}
</script>
