<div x-data="proxy()" x-init="init()">
  <div class="mb-6">
    <h1 class="text-3xl font-bold text-gray-900 dark:text-white">Proxy Settings</h1>
    <p class="text-gray-500 dark:text-gray-400 mt-1">Configure proxy for browser automation</p>
  </div>

  <div class="bg-white dark:bg-gray-800 rounded-lg shadow p-6 max-w-2xl">
    <form @submit.prevent="saveProxy">
      <div class="space-y-4">
        <div>
          <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Proxy Type</label>
          <select x-model="config.type" class="w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 text-gray-900 dark:text-white">
            <option value="none">None</option>
            <option value="http">HTTP</option>
            <option value="socks5">SOCKS5</option>
          </select>
        </div>

        <template x-if="config.type !== 'none'">
          <div class="space-y-4">
            <div>
              <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Host</label>
              <input x-model="config.host" type="text" placeholder="proxy.example.com" class="w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 text-gray-900 dark:text-white">
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Port</label>
              <input x-model="config.port" type="number" placeholder="8080" class="w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 text-gray-900 dark:text-white">
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Username (optional)</label>
              <input x-model="config.username" type="text" class="w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 text-gray-900 dark:text-white">
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Password (optional)</label>
              <input x-model="config.password" type="password" class="w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 text-gray-900 dark:text-white">
            </div>
          </div>
        </template>

        <div class="flex space-x-3 pt-4">
          <button type="submit" :disabled="saving" class="px-6 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 disabled:opacity-50">
            <span x-show="!saving">Save Configuration</span>
            <span x-show="saving">Saving...</span>
          </button>
          <button type="button" @click="testProxy" :disabled="testing || config.type === 'none'" class="px-6 py-2 border border-gray-300 dark:border-gray-600 rounded-lg hover:bg-gray-50 dark:hover:bg-gray-700 disabled:opacity-50">
            <span x-show="!testing">Test Proxy</span>
            <span x-show="testing">Testing...</span>
          </button>
        </div>
      </div>
    </form>
  </div>

  <div x-show="testResult" class="mt-6 max-w-2xl p-4 rounded-lg" :class="testResult?.success ? 'bg-green-50 dark:bg-green-900/20 border border-green-200' : 'bg-red-50 dark:bg-red-900/20 border border-red-200'">
    <p x-text="testResult?.message"></p>
  </div>
</div>

<script>
function proxy() {
  return {
    config: { type: 'none', host: '', port: '', username: '', password: '' },
    saving: false,
    testing: false,
    testResult: null,
    
    init() { this.loadConfig(); },
    
    async loadConfig() {
      try {
        const res = await fetch('/admin/proxy/data');
        const data = await res.json();
        if (data.config) this.config = { ...this.config, ...data.config };
      } catch (e) {}
    },
    
    async saveProxy() {
      this.saving = true;
      try {
        await fetch('/admin/proxy', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(this.config)
        });
        alert('Saved!');
      } catch (e) {
        alert('Failed');
      }
      this.saving = false;
    },
    
    async testProxy() {
      this.testing = true;
      try {
        const res = await fetch('/admin/proxy/test', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(this.config)
        });
        this.testResult = await res.json();
      } catch (e) {
        this.testResult = { success: false, message: 'Test failed' };
      }
      this.testing = false;
    }
  }
}
</script>
