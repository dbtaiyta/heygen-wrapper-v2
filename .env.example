# Server
PORT=3000
NODE_ENV=development

# Admin
ADMIN_PASSWORD=change-me-in-production

# Storage
VIDEO_RETENTION_HOURS=24
VIDEOS_DIR=./videos
CHROME_PROFILE_DIR=./data/chrome-profile
DATA_DIR=./data

# Queue
MAX_CONCURRENT_JOBS=1
REDIS_URL=redis://localhost:6379

# Browser
HEADED_DEBUG=false
BROWSER_TIMEOUT=60000

# Logging
LOG_LEVEL=info
